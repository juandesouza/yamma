# PostgreSQL — use nHost dashboard → Database → connection string (recommended).
# Optional: local Docker URL is in `.env.local.example` (copy to `.env.local` only if you use docker compose).
# Paste the full URL from nHost (often includes sslmode=require).
DATABASE_URL=postgresql://postgres:PASSWORD@SUBDOMAIN.db.REGION.nhost.run:5432/postgres

# App
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001

# Lucia / Session
SESSION_SECRET=your-session-secret-min-32-chars

# Mapbox
MAPBOX_ACCESS_TOKEN=your-mapbox-token

# Lemon Squeezy (cards) — API key + store/variant from https://app.lemonsqueezy.com (Products → variant ID; Settings → store)
LEMON_SQUEEZE_API_KEY=
LEMON_SQUEEZE_WEBHOOK_SECRET=
LEMON_SQUEEZE_STORE_ID=
LEMON_SQUEEZE_VARIANT_ID=
# true = test checkouts (Lemon Squeezy test products). false = live. Unset: true in development, false in production.
# LEMON_SQUEEZE_TEST_MODE=true
# List variant IDs for this store: pnpm run lemon:list-variants -w backend
#
# Local seller payout testing:
# - Lemon: use a test-mode product variant; set LEMON_SQUEEZE_TEST_MODE=true if needed. After checkout,
#   the web /checkout/return page confirms the order in development (webhooks rarely hit localhost).
# - In-app "crypto": buyer uses "Dev: add test crypto balance" on checkout (NODE_ENV=development),
#   then "Pay with in-app crypto". Seller sees earnings under Profile → How you get paid.

# Delivery webhook (future driver app)
DELIVERY_WEBHOOK_SECRET=
# Future Uber-like dispatch API endpoint (called by seller "Ready and send")
DELIVERY_DISPATCH_URL=
DELIVERY_DISPATCH_TOKEN=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: native / Expo app ID tokens use these as allowed JWT `aud` (match mobile EXPO_PUBLIC_* IDs)
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_EXPO_CLIENT_ID=
# Must match "Authorized redirect URIs" in Google Cloud (Next app, not the API port):
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
# Public web app origin (Next/Vercel), not the API host — e.g. https://yamma-web.vercel.app in production.
FRONTEND_URL=http://localhost:3000
# Comma-separated HTTPS origins allowed for mobile Lemon return when they differ from FRONTEND_URL (production).
# PAYMENT_RETURN_ORIGIN_ALLOWLIST=https://staging.example.com

# ─── Fiat → USDC on-ramp (app checkout + fund wallet use Transak in the UI)
# Partner dashboard → API keys + Create Widget URL access token. Webhook: POST {API_URL}/payments/webhooks/transak
TRANSAK_API_KEY=
TRANSAK_ACCESS_TOKEN=
# Domain allowlisted in Transak (e.g. localhost or your production host, no scheme)
TRANSAK_REFERRER_DOMAIN=localhost
# true = staging gateway (default in development)
# TRANSAK_STAGING=true
# EVM address that receives USDC from buys (balances updated via Transak webhook)
ONRAMP_SETTLEMENT_WALLET=
# Transak network code for USDC (e.g. polygon, ethereum)
TRANSAK_USDC_NETWORK=polygon

# Optional: MoonPay / Ramp keys if you call those providers from custom code (not used by default checkout UI)
# MOONPAY_API_KEY=
# RAMP_API_KEY=
