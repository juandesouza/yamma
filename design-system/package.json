{
  "name": "@yamma/design-system",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "react-native": "./src/index.native.ts",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./tokens": {
      "import": "./dist/tokens/index.mjs",
      "types": "./dist/tokens/index.d.mts"
    },
    "./components": {
      "import": "./dist/components/index.mjs",
      "types": "./dist/components/index.d.mts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/tokens/index.ts src/components/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts src/tokens/index.ts src/components/index.ts --format esm --dts --watch"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0",
    "react-native-svg": ">=15.0.0"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    },
    "react-native-svg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@react-native-masked-view/masked-view": "0.3.2",
    "@types/react": "^19.1.0",
    "expo-linear-gradient": "~15.0.8",
    "react": "^19.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0"
  }
}
