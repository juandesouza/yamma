# Required on a physical phone: your computer's LAN IP + API port (Nest default 3001).
# No trailing slash. Phone and PC must be on the same Wi‑Fi (not “guest” Wi‑Fi if it isolates clients).
# EXPO_PUBLIC_API_URL=http://192.168.1.10:3001
#
# Lemon return: public HTTPS origin that serves /payment/app-redirect. Often the **same** as EXPO_PUBLIC_API_URL
# (Nest serves the bridge on the API host). Or use a separate Next.js tunnel (ngrok port 3000). No trailing slash.
# EXPO_PUBLIC_PAYMENT_RETURN_BASE_URL=https://your-api-or-web.ngrok-free.app
#
# Quick check: on the phone’s browser open http://YOUR_IP:3001/restaurants — you should see JSON.
# If that fails: wrong IP, firewall blocking 3001, API not running, or AP isolation on the router.

# Google Sign-In (same Google Cloud project as the web app / Nest GOOGLE_CLIENT_ID).
# Web client ID (OAuth client type "Web application") — used by Expo / iOS simulator.
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxxx.apps.googleusercontent.com
# Android OAuth client ID (recommended for production). If omitted, the web client ID above is reused so Expo Auth works on device.
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=xxxxx.apps.googleusercontent.com
# iOS OAuth client ID (iOS builds).
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=xxxxx.apps.googleusercontent.com
# Optional: Expo Go / dev proxy client if you use a separate Web client for Expo.
# EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=xxxxx.apps.googleusercontent.com

# Expo project full name used by auth.expo.io proxy in Expo Go (no Android keystore required).
# Format: @your-expo-username/yamma
# EXPO_PUBLIC_EXPO_PROJECT_FULL_NAME=@your-expo-username/yamma

# Nest API must list every ID token `aud` you use, e.g. in backend/.env:
# GOOGLE_CLIENT_ID=<same as web>
# GOOGLE_ANDROID_CLIENT_ID=<same as EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID>
# GOOGLE_IOS_CLIENT_ID=<same as EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID>
# GOOGLE_EXPO_CLIENT_ID=<optional, if you use EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID>
