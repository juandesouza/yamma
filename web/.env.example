NEXT_PUBLIC_API_URL=http://localhost:3001
# Socket.IO uses HTTP(S) origin (not ws://). Must match API host/port.
NEXT_PUBLIC_WS_URL=http://localhost:3001
NEXT_PUBLIC_MAPBOX_TOKEN=

# Optional: server-side OAuth callback uses this to reach the API (try 127.0.0.1 if localhost fails)
# INTERNAL_API_URL=http://127.0.0.1:3001

# Same values as backend. Client secret is server-only (signs OAuth state for /api/auth/google).
# Google Cloud → APIs & Services → Credentials → your OAuth 2.0 Web client → Authorized redirect URIs.
# Add each origin you use, exactly (scheme + host + path, no trailing slash after .../callback):
#   http://localhost:3000/api/auth/google/callback
#   https://yamma-web.vercel.app/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Force redirect_uri + token exchange origin (must match an Authorized redirect URI above).
# Production (Vercel): set to your live site origin, e.g. https://yamma-web.vercel.app
# Local: use if you open the site as http://127.0.0.1:3000 or http://[::1]:3000 instead of localhost.
# OAUTH_PUBLIC_ORIGIN=http://localhost:3000
